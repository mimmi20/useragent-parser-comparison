{
  "name": "mimmi20/useragent-parser-comparison",
  "description": "project to compare some useragent parsers",
  "license": "MIT",
  "type": "library",
  "homepage": "https://github.com/diablomedia/useragent-parser-comparison",
  "require": {
    "php": "~8.5.0 || ~8.6.0",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "composer-runtime-api": "^2.0.0",
    "mimmi20/ua-data-mapper": "^6.0.0",
    "ramsey/uuid": "^4.9.2",
    "symfony/console": "^7.3.5"
  },
  "require-dev": {
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "ergebnis/composer-normalize": "^2.50.0",
    "infection/infection": "^0.32.6",
    "jbelien/phpstan-sarif-formatter": "^1.2.0",
    "mimmi20/coding-standard": "^8.0.0",
    "nikic/php-parser": "^5.7.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.1.46",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "rector/rector": "^2.3.9",
    "rector/type-perfect": "^2.1.2",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "symfony/process": "^8.0.8",
    "symplify/phpstan-rules": "^14.9.11",
    "tomasvotruba/cognitive-complexity": "^1.1.0",
    "tomasvotruba/type-coverage": "^2.1.0",
    "tomasvotruba/unused-public": "^2.2.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "UserAgentParserComparison\\": "src/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "lock": false,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  },
  "scripts": {
    "php-cs-fixer-check": "php-cs-fixer fix --dry-run -vv",
    "php-cs-fixer-fix": "php-cs-fixer fix -vv",
    "phpstan": "phpstan analyse -c phpstan.neon --memory-limit=768M --no-progress",
    "prettier-check": "npx prettier -l \"**/*.js\"",
    "prettier-fix": "npx prettier --write \"**/*.js\""
  }
}
